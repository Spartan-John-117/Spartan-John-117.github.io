{
  "[python]": {
    "editor.codeActionsOnSave": {
      "source.organizeImports.ruff": "explicit"
    },
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "eslint.workingDirectories": [
    {
      "mode": "auto"
    }
  ],
  "files.eol": "\n",
  "prettier.configPath": ".prettierrc.json",
  "prettier.useEditorConfig": false,
  "python.analysis.autoImportCompletions": true,
  "python.analysis.autoFormatStrings": true,
  "python.analysis.typeCheckingMode": "standard",
  "python.testing.pytestArgs": [
    "-s"
    // "--no-cov"
    // --no-cov: Ensure the VSCode debugger keeps stopping on breakpoints
    //           see https://github.com/Microsoft/vscode-python/issues/693 for details
  ],
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
    "[c,cpp]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",

  "cmake.configureOnOpen": false,
  "cmake.buildDirectory": "${workspaceFolder}/.local/cmake/build",
  "cmake.configureSettings": {
    "CMAKE_BUILD_TYPE": "Debug",
    "CMAKE_TOOLCHAIN_FILE": "${workspaceFolder}/.local/vcpkg/scripts/buildsystems/vcpkg.cmake",
    "BUILD_TESTING": "1"
  },
  "cmake.debugConfig": {
    "console": "integratedTerminal"
  }
}
